NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# Admin key — full access to all instances (min 16 chars).
# Generate something strong for any shared/staging/prod host, e.g.:
#   openssl rand -hex 24
ADMIN_API_KEY=change-me-admin-key-32chars!!

# Postgres (app meta + zapo store mailbox_*)
DATABASE_URL=postgresql://zapo:zapo@localhost:5555/zapo

# ── Postgres pool tuning ────────────────────────────────────────────────────
# DB_POOL_MAX=20               # max clients in the pg pool
# DB_CONNECTION_TIMEOUT_MS=5000  # wait for a free connection before erroring
# DB_IDLE_TIMEOUT_MS=10000     # close idle pool clients after this long
# DB_STATEMENT_TIMEOUT_MS=30000  # abort a single query running longer than this

# Redis cache (optional — falls back to in-memory)
# Host port from docker-compose is 16379 → container 6379. In-network: redis://redis:6379
REDIS_URL=redis://localhost:16379

# Avatar revalidation TTL (seconds). Default 86400 = 24h.
# Controls when GET profile-picture re-queries WhatsApp (bytes live in MEDIA_STORAGE).
# Within TTL: serve durable file without WA IQ. Set 0 to revalidate every request.
# PROFILE_PICTURE_CACHE_TTL_SECONDS=86400

AUTO_CONNECT_ON_BOOT=true
RECONNECT_MAX_ATTEMPTS=10
WEBHOOK_TIMEOUT_MS=5000

# ── Security / realtime knobs ───────────────────────────────────────────────
# TRUST_PROXY=true                 # trust X-Forwarded-* (set false if exposed without a reverse proxy)
# TRUST_PROXY_HOPS=1
# SSE_MAX_CONNECTIONS=200
# SSE_MAX_CONNECTIONS_PER_ACTOR=10
# HISTORY_IMPORT_DEBOUNCE_MS=30000 # coalesce history_sync full re-import
# MEDIA_DOWNLOAD_CONCURRENCY=4
# CALL_RECORDING_MAX_SECONDS=7200
WEBHOOK_WORKER_INTERVAL_MS=2000
WEBHOOK_DEFAULT_ATTEMPTS=5
VOIP_MAX_CONCURRENT_CALLS=10
VOIP_END_CALL_ON_WS_CLOSE=false
MEDIA_TMP_DIR=/tmp/zapo-rest-media

# History sync after QR pair / reconnect
HISTORY_SYNC_ENABLED=true
HISTORY_REQUIRE_FULL_SYNC=false
MEDIA_AUTO_DOWNLOAD=true

# ---------------------------------------------------------------------------
# WAM — WhatsApp Web client-side analytics (w:stats)
# ---------------------------------------------------------------------------
# Plugin @zapo-js/wam on every WaClient session. Emits the same kind of
# telemetry batches a real WhatsApp Web tab sends after login, for wire
# parity / a less “headless” fingerprint.
#
# - NOT app metrics, logs, or OpenAPI — no REST/SSE/media/VoIP contract change
# - Default: true (on when unset)
# - Disable: WAM_ENABLED=false then restart the API process
# Upstream: https://zapo.to/guides/wam
WAM_ENABLED=true

# Media storage: local | s3
# --- local ---
# MEDIA_STORAGE=local
# MEDIA_LOCAL_DIR=/tmp/zapo-rest-media/objects
# MEDIA_PUBLIC_BASE_URL=http://localhost:3000/v1/media

# --- MinIO (docker compose): API localhost:19000, console :19001 ---
MEDIA_STORAGE=s3
S3_ENDPOINT=http://localhost:19000
S3_REGION=us-east-1
S3_BUCKET=zapo-media
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=http://localhost:19000/zapo-media

# Inside docker-compose network use:
#   S3_ENDPOINT=http://minio:9000
#   S3_PUBLIC_URL=http://localhost:19000/zapo-media

# GET .../messages/:id/media: 302 to storage (true) vs streaming through the API (false)
MEDIA_REDIRECT_DOWNLOADS=true
# TTL (seconds) for presigned GET URLs handed out to clients
MEDIA_PRESIGN_TTL_SECONDS=3600
# Public endpoint used to sign GET URLs when it differs from S3_ENDPOINT (see docker-compose.yml)
S3_PRESIGN_ENDPOINT=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated browser origins (dashboard on another host, Vite dev, etc.).
# Unset: development/test → allow any Origin; production → CORS off (same-origin only).
# Use * to reflect any Origin (not recommended in production).
# CORS_ORIGINS=https://app.example.com,http://localhost:5173

# ── Rate limit (/v1 only) ─────────────────────────────────────────────────────
# Unset RATE_LIMIT_ENABLED → on in production, off in development/test.
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_MAX=300
# RATE_LIMIT_TIME_WINDOW_MS=60000

# ── Production notes ──────────────────────────────────────────────────────────
# Full checklist: README “Production checklist” + docs/PRODUCTION-CONSISTENCY.md
# - Put the API behind HTTPS + network ACL; /docs and /guide are public by default.
# - Prefer X-Api-Key / Authorization headers (SSE fetch, REST). Query ?apiKey= is
#   only for native EventSource / some browser WebSockets.
# - Never ship compose defaults (minioadmin / zapo / change-me-admin-key) to the public internet.
# - App rate-limits /v1 (defaults above); still put a reverse-proxy limit in front for defense in depth.
# - Single process owns live WA sessions (sticky sessions if you scale horizontally).
# - Realtime app events: SSE GET /v1/events. VoIP stays on WebSocket.
# - Optional compose overrides: MINIO_ROOT_USER / MINIO_ROOT_PASSWORD (see docker-compose.yml).
